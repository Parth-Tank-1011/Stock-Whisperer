APP_NAME=Stock Whisperer API
APP_VERSION=1.0.0
APP_ENV=development

HISTORY_PERIOD=2y
HISTORY_INTERVAL=1d
LOOKBACK_DAYS=60
MODEL_EPOCHS=10
MODEL_BATCH_SIZE=16
RETRAIN_AFTER_DAYS=3
CACHE_TTL_SECONDS=900
PREDICTION_CACHE_TTL_SECONDS=300
LIVE_CACHE_TTL_SECONDS=5

MODEL_DIR=storage/models
METADATA_DIR=storage/meta
# Comma-separated origins, or * (dev only). Production example:
# CORS_ORIGINS=https://stock-whisperer-sigma.vercel.app
CORS_ORIGINS=*
# Optional frontend URL alias added automatically to CORS allowlist.
# FRONTEND_URL=https://stock-whisperer-sigma.vercel.app

# Optional: serve Vite build from FastAPI (Docker image sets this automatically).
# FRONTEND_DIST_DIR=/app/frontend/dist
YFINANCE_CACHE_DIR=storage/yfinance_cache
LOG_DIR=storage/logs
ENABLE_XGBOOST=false
ENABLE_DEEP_MODELS=false

# Prefer a managed DB in production.
# Render persistent-disk SQLite example: sqlite:////var/data/stock_whisperer.db
# Supabase/Render Postgres examples (both supported):
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/postgres?sslmode=require
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require
DATABASE_URL=sqlite:///./storage/app.db
JWT_SECRET_KEY=change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=80
REQUEST_LOG_ENABLED=true

EXTERNAL_API_RETRIES=2
EXTERNAL_API_RETRY_DELAY_MS=400
